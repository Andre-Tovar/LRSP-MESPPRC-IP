# 
# Makefile for building a MINTO application with Osi

#
# To create a MINTO executable, you must adjust the following three macros in 
#  this Makefile
# 
# 1) Ensure that CPLEX_DIR is set to the location of the root directory
#    of CPLEX and CPLEXLIB_DIR is set to the location of CPLEX library files.
#
# 2) Ensure that MINTOLIBDIR is pointing to the directory containing libminto.a
#    that came with this distribution
# 
# 3) type 'make' in the APPL directory.  You may adjust CFLAGS and LDFLAGS as 
#    necessary for your purposes.


CPLEX_DIR = /usr/local/cplex91
CPLEXLIB_DIR = /usr/local/cplex91/lib/x86_RHEL3.0_3.2/static_pic
MINTOLIBDIR= ..

DEFINES  = -DLPSOLVER_CLP
INCLUDES = -I$(CPLEX_DIR)/include

CXX		= g++
CXXFLAGS	= -Wall -g
LD		= g++
LDFLAGS		= -g


#
# BASIC MACRO DEFINITIONS
#

APPLNAME =   minto

APPLINCLS =  minto.h

APPLSRCS =   a_bounds.cpp\
             a_cons.cpp\
             a_delcon.cpp\
             a_divide.cpp\
             a_exit.cpp\
             a_fathom.cpp\
             a_feas.cpp\
             a_init.cpp\
             a_initlp.cpp\
             a_mps.cpp\
             a_node.cpp\
             a_prep.cpp\
             a_primal.cpp\
             a_quit.cpp\
             a_rank.cpp\
             a_termlp.cpp\
             a_termnd.cpp\
	a_vars.cpp\
	minto.cpp\
	initcplex.cpp\


APPLOBJS =   $(APPLSRCS:.cpp=.o)

#
# MAKE SURE THAT THE FIRST TARGET IS THE RIGHT ONE
#

first : $(APPLNAME)

#
# META RULE FOR MAKING .o's FROM .cpp's, I.E., COMPILATION
#

.cpp.o:
	$(CXX) $(CXXFLAGS) $(DEFINES) $(INCLUDES) -c $< -o $@;


#
# Note: Libs must (seemingly) be in this order.
#

$(APPLNAME): $(APPLOBJS)
	$(LD) $(LDFLAGS) -o $@ $(APPLOBJS) -L$(MINTOLIBDIR) -lminto -lminto-cplex -L$(CPLEXLIB_DIR) -lcplex -lm -lpthread 


clean:
	rm -f $(APPLOBJS) $(APPLNAME)

#
# DEPENDENCIES
#

$(APPLOBJS) :  $(APPLINCLS)
