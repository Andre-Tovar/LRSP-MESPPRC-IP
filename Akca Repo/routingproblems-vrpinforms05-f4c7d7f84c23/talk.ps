%%BeginDocument: M-n101-k10-2.ps
%!PS-Adobe-3.0 EPSF-3.0
%%Creator: Tk Canvas Widget
%%For: Ted Ralphs,Room 473 Mohler Lab,8-4784,
%%Title: Window .top0.c
%%CreationDate: Thu Nov  2 12:37:07 2000
%%BoundingBox: 90 141 522 651
%%Pages: 1
%%DocumentData: Clean7Bit
%%Orientation: Landscape
