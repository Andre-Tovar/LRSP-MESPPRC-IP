#include "header.h"

typedef struct Label{
  int Cap;
  int Time;
  int *path;
} LABEL;

typedef struct Label2{
  LABEL labeldata;
  struct Label2 *next;
  struct Label2 *prev;
} LABEL_NODE;

int mindistfacility (double *d,int size) 
{
  int i,index;
  double min;
  min=2*MY_INF;
  index=-1;
  for (i=0;i<size;i++){
    if (d[i]<min){
      min=d[i];
      index=i;
    }
  }
  
  return(index);
}
int GenerateSoln (double **d,int FAC, int *numcust, LABEL_NODE **List) 
{

  LABEL_NODE *SolnList,*temp;
  int i,j,k,num,numcolumn;
  SolnList=0;
  double time1,time2,time3,time;

  num=0;
  numcolumn=0;

  for (i=0;i<NCust;i++){
    if (Demand[i]<=VCap){
      if (2*d[i][NCust+FAC]<=TIMELIMIT){
        
	///////////////////////path with 1 customer
	temp=(LABEL_NODE *) calloc(1,sizeof(LABEL_NODE));
        temp->labeldata.Cap=Demand[i];
        temp->labeldata.Time=2*d[i][i+FAC];
        temp->labeldata.path= (int *) calloc (NCust+1,sizeof(int));
        temp->labeldata.path[0]=i;
	temp->labeldata.path[1]=-1;
	num=num+1;
	numcolumn++;
	temp->prev=0;
	temp->next=SolnList;
	if (SolnList)		 
	  SolnList->prev=temp;
	SolnList=temp;
	temp=0;

        if (i!=NCust-1){
	  for (j=i+1;j<NCust;j++){
	    if (Demand[i]+Demand[j]<=VCap){
	      if (d[NCust+FAC][i]+d[i][j]+d[j][NCust+FAC]<=TIMELIMIT){
		
		///////////////////////path with 2 customer
		temp=(LABEL_NODE *) calloc(1,sizeof(LABEL_NODE));
		temp->labeldata.Cap=Demand[i]+Demand[j];
		temp->labeldata.Time=d[NCust+FAC][i]+d[i][j]+d[j][NCust+FAC];
		temp->labeldata.path= (int *) calloc (NCust+1,sizeof(int));
		temp->labeldata.path[0]=i;
		temp->labeldata.path[1]=j;
		temp->labeldata.path[2]=-1;
		num=num+2;
		numcolumn++;
		temp->prev=0;
		temp->next=SolnList;
		if (SolnList)		 
		  SolnList->prev=temp;
		SolnList=temp;
		temp=0;
		
		if (j!=NCust-1) {
		  for (k=j+1;k<NCust;k++){
		    time=0;
		    time1=0;
		    time2=0;
		    time3=0; 
		    if (Demand[i]+Demand[j]+Demand[k]<=VCap){
		      time1=d[NCust+FAC][i]+d[i][j]+d[j][k]+d[k][NCust+FAC]; //i-j-k
		      time2=d[NCust+FAC][i]+d[i][k]+d[k][j]+d[j][NCust+FAC]; //i-k-j
		      time3=d[NCust+FAC][k]+d[k][i]+d[i][j]+d[j][NCust+FAC]; //k-i-j
		      time=time1;
		      if (time>time2)
			time=time2;
		      if (time>time3)
			time=time3;
		      if (time<=TIMELIMIT){
			
			////////////////////////path with 3 customers
			temp=(LABEL_NODE *) calloc(1,sizeof(LABEL_NODE));
			temp->labeldata.Cap=Demand[i]+Demand[j]+Demand[k];
			temp->labeldata.Time=time;
			temp->labeldata.path= (int *) calloc (NCust+1,sizeof(int));
		        if (time==time1){
			  temp->labeldata.path[0]=i;
			  temp->labeldata.path[1]=j;
			  temp->labeldata.path[2]=k;
			  temp->labeldata.path[3]=-1;
			}//if time1
			else if (time==time2){
			  temp->labeldata.path[0]=i;
			  temp->labeldata.path[1]=k;
			  temp->labeldata.path[2]=j;
			  temp->labeldata.path[3]=-1;
			}//if time2
			else{
			  temp->labeldata.path[0]=k;
			  temp->labeldata.path[1]=i;
			  temp->labeldata.path[2]=j;
			  temp->labeldata.path[3]=-1;
			}//if time3
			num=num+3;
			numcolumn++;
			temp->prev=0;
			temp->next=SolnList;
			if (SolnList)		 
			  SolnList->prev=temp;
			SolnList=temp;
			temp=0;
	      
		      }//if timelimit for 3 cust
		    }//if demand 3-cust 
		  }//for all k
		} //if j!=NCust-1
		
	      }//timelimit for 2 customer
	    }//cap for 2
	  } //for all j
	}//if i!=NCust-1
    
      } //if timelimit for 1 cust
    }//if demand
  }//for all i
  *numcust=num;
  printf("numcust:%d, numcolumn:%d \n",*numcust,numcolumn);
  *List=SolnList;
  return (numcolumn);

}


 
